{
  "expo": {
    "name": "OlistPlayground2",
    "slug": "OlistPlayground2",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "olistplayground2",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.justinbutler1.OlistPlayground2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.justinbutler1.OlistPlayground2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5F7FA",
          "dark": {
            "backgroundColor": "#0B0F1A"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "defaultChannel": "tracker-reminders"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Olist to choose custom covers for your tracked items.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-document-picker",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Olist to protect private tracker settings and backups.",
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Olist to confirm protected backup actions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08ee3333-5796-4f73-a9a2-979405532e4e"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/08ee3333-5796-4f73-a9a2-979405532e4e"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
